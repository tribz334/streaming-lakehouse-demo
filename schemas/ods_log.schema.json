{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ustc.example/schema/ods_log.schema.json",
  "title": "ODS Ad Log Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "ts",
    "advertiser_id",
    "campaign_id",
    "unit_id",
    "creative_id",
    "media",
    "region",
    "user_id",
    "event_type",
    "bid_price",
    "spend",
    "gmv",
    "order_id",
    "schema_version"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" },
    "advertiser_id": { "type": "string" },
    "campaign_id": { "type": "string" },
    "unit_id": { "type": "string" },
    "creative_id": { "type": "string" },
    "media": { "type": "string" },
    "region": { "type": "string" },
    "user_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": ["impression", "click", "conversion", "order"]
    },
    "bid_price": { "type": "number", "minimum": 0 },
    "spend": { "type": "number", "minimum": 0 },
    "gmv": { "type": "number", "minimum": 0 },
    "order_id": { "type": ["string", "null"] },
    "schema_version": { "type": "integer", "minimum": 1 }
  }
}
