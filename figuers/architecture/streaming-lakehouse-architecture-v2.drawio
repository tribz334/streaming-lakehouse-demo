    <mxCell id="title" value="广告流批一体湖仓系统总体架构" style="text;html=1;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="460" y="20" width="900" height="45" as="geometry"/></mxCell>
